<section class="products" id="products"></section>

<script>
let products = JSON.parse(localStorage.getItem("products")) || [];

let area = document.getElementById("products");

products.forEach(product => {
  area.innerHTML += `
    <div class="card">
      <img src="${product.image}" width="200">
      <h2>${product.name}</h2>
      <p>$${product.price}</p>
    </div>
  `;
});
</script>